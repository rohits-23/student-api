[flake8]
max-line-length = 100

# E203 — whitespace before ':' (conflicts with Black)
# W503 — line break before binary operator (conflicts with Black / PEP 8 update)
extend-ignore = E203, W503

exclude =
    .git,
    __pycache__,
    venv,
    .venv,
    env,
    migrations,
    build,
    dist

per-file-ignores =
    # Allow unused imports in __init__ files (they are deliberate re-exports)
    app/api/v1/__init__.py: F401
    app/models/__init__.py: F401
