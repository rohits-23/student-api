# Flask
FLASK_APP=run.py
FLASK_ENV=development
FLASK_HOST=0.0.0.0
FLASK_PORT=5000
FLASK_DEBUG=true

# Security — change this to a long random string in production
SECRET_KEY=change-this-to-a-long-random-string

# ── Local development (SQLite) ─────────────────────────────────────────────
# Used when running `python run.py` directly (no Docker).
DATABASE_URL=sqlite:///students_dev.db

# ── Docker Compose (PostgreSQL) ───────────────────────────────────────────
# docker-compose.yml constructs DATABASE_URL from these vars automatically.
DB_USER=student
DB_PASSWORD=student_password
DB_NAME=students_db
DB_PORT=5432

# Image name and semver tag (read by docker-compose and make targets)
IMAGE_NAME=student-api
VERSION=1.0.0

# Gunicorn tuning (used inside Docker)
GUNICORN_WORKERS=2
GUNICORN_THREADS=2

# Test database (used by pytest)
TEST_DATABASE_URL=sqlite:///:memory:

# Logging level: DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=INFO
